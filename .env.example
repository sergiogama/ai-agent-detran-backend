# ============================================================================
# CONFIGURAÇÃO DO BACKEND - DETRAN AGENT
# ============================================================================
#
# IMPORTANTE: Todas as variáveis são OPCIONAIS. O backend iniciará mesmo sem
# configuração, mas os serviços correspondentes não estarão disponíveis.
#
# Para usar um serviço específico, configure TODAS as variáveis daquele grupo.
# ============================================================================

# ============================================================================
# IBM Cloud Object Storage (COS) - OPCIONAL
# ============================================================================
# Necessário para upload de imagens de CNH
# Configure TODAS as 4 variáveis abaixo para habilitar o serviço COS
#
# COS_API_KEY=your-cos-api-key-here
# COS_INSTANCE_CRN=your-cos-instance-crn-here
# COS_ENDPOINT=https://s3.br-sao.cloud-object-storage.appdomain.cloud
# COS_BUCKET_NAME=your-bucket-name

# ============================================================================
# IBM Db2 Warehouse on Cloud - OPCIONAL
# ============================================================================
# Necessário para consultas ao banco de dados Db2
# Configure TODAS as variáveis abaixo para habilitar o serviço Db2
#
# DB2_HOSTNAME=your-hostname.databases.appdomain.cloud
# DB2_PORT=32286
# DB2_DATABASE=bludb
# DB2_USERNAME=your-username
# DB2_PASSWORD=your-password
# DB2_SECURITY=SSL
# DB2_VERIFY_SSL=false

# ============================================================================
# IBM Watsonx Orchestrate - OPCIONAL
# ============================================================================
# Necessário para chat com o agente Watsonx
# Configure TODAS as 3 variáveis abaixo para habilitar o serviço Orchestrate
#
# ORCHESTRATE_API_URL=https://your-instance.watsonx-orchestrate.ibm.com/api/v1
# ORCHESTRATE_API_KEY=your-orchestrate-api-key
# ORCHESTRATE_AGENT_ID=your-agent-id

# ============================================================================
# Backend Configuration
# ============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true

# ============================================================================
# CORS Origins
# ============================================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ============================================================================
# Upload Configuration
# ============================================================================
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=[".jpg",".jpeg",".png",".pdf"]