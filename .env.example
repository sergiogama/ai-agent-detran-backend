# ============================================================================
# IBM Cloud Object Storage (COS)
# ============================================================================
COS_API_KEY=your-cos-api-key-here
COS_INSTANCE_CRN=your-cos-instance-crn-here
COS_ENDPOINT=https://s3.br-sao.cloud-object-storage.appdomain.cloud
COS_BUCKET_NAME=your-bucket-name

# ============================================================================
# IBM Db2 Warehouse on Cloud
# ============================================================================
DB2_HOSTNAME=your-hostname.databases.appdomain.cloud
DB2_PORT=32286
DB2_DATABASE=bludb
DB2_USERNAME=your-username
DB2_PASSWORD=your-password
DB2_SECURITY=SSL
DB2_VERIFY_SSL=false

# ============================================================================
# IBM Watsonx Orchestrate
# ============================================================================
ORCHESTRATE_API_URL=https://your-instance.watsonx-orchestrate.ibm.com/api/v1
ORCHESTRATE_API_KEY=your-orchestrate-api-key
ORCHESTRATE_AGENT_ID=your-agent-id

# ============================================================================
# Backend Configuration
# ============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true

# ============================================================================
# CORS Origins
# ============================================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ============================================================================
# Upload Configuration
# ============================================================================
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=[".jpg",".jpeg",".png",".pdf"]